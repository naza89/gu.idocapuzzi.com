# =============================================================================
# GÜIDO CAPUZZI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git!
# =============================================================================

# Supabase (Public - safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (Private - server-side only, NEVER expose)
SUPABASE_SERVICE_ROLE_KEY=

# NAVE (Banco Galicia — Payment Gateway)
NAVE_CLIENT_ID=
NAVE_CLIENT_SECRET=
NAVE_POS_ID=
NAVE_AUDIENCE=https://naranja.com/ranty/merchants/api
NAVE_ENVIRONMENT=sandbox

# NAVE callback (optional - where the user is redirected after paying)
# NAVE_CALLBACK_URL=https://xn--guidocapuzzi-vpb.com/checkout/confirmacion

# OCA ePak (to be configured in later phases)
# OCA_USER=
# OCA_PASSWORD=
# OCA_ACCOUNT=
# OCA_CUIT=
